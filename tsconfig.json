{
    "compilerOptions": {
        "target": "ES2020",
        "module": "node20",
        "moduleResolution": "nodenext",
        "resolveJsonModule": true,
        "allowJs": true,
        "outDir": "./dist",
        "rootDir": "./",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "ignoreDeprecations": "5.0",
        "types": ["bun-types"]
    },
    "include": ["src/**/*.ts", "tests/**/*.ts"],
    "exclude": ["node_modules", "dist"]
}