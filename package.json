{
  "name": "ollama-agent",
  "version": "1.0.0",
  "private": true,
  "main": "src/server.ts",
  "license": "MIT",
  "scripts": {
    "prestart": "lsof -ti:5002 | xargs kill -9 || true",
    "start": "bun run build && bun dist/src/server.js",
    "predev": "lsof -ti:5002 | xargs kill -9 || true",
    "dev": "bun --watch src/server.ts",
    "build": "tsc -p tsconfig.build.json && mkdir -p dist/src/prompt/templates && cp -r src/prompt/templates/* dist/src/prompt/templates/",
    "clean": "rm -rf dist && rm -rf .faiss_store",
    "test": "bun test --ignore-path dist",
    "test:unit": "bun test tests/unit/*.ts",
    "pretest:integration": "./scripts/pre-test.sh",
    "test:integration": "NODE_ENV=test bun test tests/integration",
    "posttest:integration": "./scripts/post-test.sh",
    "test:all": "bun run clean && bun run test:unit && bun run test:integration && bun run test:eval",
    "pretest:eval": "REINITIALIZE_KB=true ./scripts/pre-test.sh",
    "test:eval": "bunx promptfoo eval",
    "posttest:eval": "./scripts/post-test.sh",
    "pretest:eval:quick": "REINITIALIZE_KB=true ./scripts/pre-test.sh",
    "test:eval:quick": "bunx promptfoo eval --tests 'tests/evals/retrieval/*.yaml'",
    "posttest:eval:quick": "./scripts/post-test.sh",
    "pretest:eval:full": "REINITIALIZE_KB=true ./scripts/pre-test.sh",
    "test:eval:full": "bunx promptfoo eval",
    "posttest:eval:full": "./scripts/post-test.sh",
    "pretest:eval:retrieval": "REINITIALIZE_KB=true ./scripts/pre-test.sh",
    "test:eval:retrieval": "bunx promptfoo eval --tests 'tests/evals/retrieval/*.yaml'",
    "posttest:eval:retrieval": "./scripts/post-test.sh",
    "pretest:eval:generation": "REINITIALIZE_KB=true ./scripts/pre-test.sh",
    "test:eval:generation": "bunx promptfoo eval --tests 'tests/evals/generation/*.yaml'",
    "posttest:eval:generation": "./scripts/post-test.sh",
    "test:eval:retrieval:symptoms": "bunx promptfoo eval --tests tests/evals/retrieval/symptoms.yaml",
    "test:eval:retrieval:billing": "bunx promptfoo eval --tests tests/evals/retrieval/billing.yaml",
    "test:eval:retrieval:contacts": "bunx promptfoo eval --tests tests/evals/retrieval/contacts.yaml",
    "test:eval:retrieval:diets": "bunx promptfoo eval --tests tests/evals/retrieval/diets.yaml",
    "test:eval:retrieval:hot_topics": "bunx promptfoo eval --tests tests/evals/retrieval/hot_topics.yaml",
    "test:eval:retrieval:packages": "bunx promptfoo eval --tests tests/evals/retrieval/medical_package.yaml",
    "test:eval:retrieval:boundaries": "bunx promptfoo eval --tests tests/evals/retrieval/boundaries.yaml",
    "test:eval:generation:format":     "bunx promptfoo eval --tests tests/evals/generation/GEN-01-output-format.yaml",
    "test:eval:generation:accuracy":    "bunx promptfoo eval --tests tests/evals/generation/GEN-02-medical-accuracy.yaml",
    "test:eval:generation:safety":      "bunx promptfoo eval --tests tests/evals/generation/GEN-03-safety-critical.yaml",
    "test:eval:generation:oos":         "bunx promptfoo eval --tests tests/evals/generation/GEN-04-out-of-scope.yaml",
    "test:eval:generation:robustness":  "bunx promptfoo eval --tests tests/evals/generation/GEN-05-robustness.yaml",
    "test:eval:generation:chat":        "bunx promptfoo eval --tests tests/evals/generation/GEN-06-conversational.yaml",
    "test:eval:view": "bunx promptfoo view",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@langchain/community": "^1.1.27",
    "@langchain/core": "^0.3.40",
    "@langchain/langgraph": "^0.2.49",
    "@langchain/ollama": "^0.2.0",
    "@langchain/textsplitters": "^1.0.1",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "axios": "^1.14.0",
    "body-parser": "^1.20.3",
    "cors": "2.8.5",
    "express": "^4.18.2",
    "express-graphql": "^0.12.0",
    "faiss-node": "^0.5.1",
    "graphql": "^16.10.0",
    "graphql-tag": "^2.12.6",
    "graphql-tools": "^9.0.13",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^2.7.0",
    "nunjucks": "^3.2.4",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "qs": "^6.14.0",
    "stopwords-iso": "^1.1.0",
    "winston": "^3.11.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/node": "^20.10.0",
    "@types/node-fetch": "^2.6.9",
    "@types/nunjucks": "^3.2.6",
    "@types/pg": "^8.20.0",
    "bun-types": "^1.3.11",
    "jest": "^30.3.0",
    "nodemon": "^3.0.0",
    "promptfoo": "^0.121.5",
    "rimraf": "^3.0.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  },
  "repository": "https://github.com/tienpham93/OllamaAgent.git",
  "author": "tien pham <phamminhtien7693@gmail.com>"
}
