generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model User {
  id        Int      @id @default(autoincrement())
  fullname  String
  username  String   @unique
  password  String
  gender    String
  age       String
  email     String
  user_type String
  tickets   Ticket[]
}

model Ticket {
  id          Int      @id @default(autoincrement())
  title       String
  content     String
  createdBy   String?
  createdDate DateTime @default(now())
  status      String
  email       String?
  User        User?    @relation(fields: [createdBy], references: [username])
}

model Analytic {
  id           Int      @id @default(autoincrement())
  userMessage  String
  botMessage   String
  vote         String
  evalMetadata Json?
  createdAt    DateTime @default(now())
}

model Monitoring {
  id                Int      @id @default(autoincrement())
  userMessage       String
  botMessage        String
  isManIntervention Boolean
  evalMetadata      Json?
  createdAt         DateTime @default(now())
}

model KnowledgeRule {
  id                String   @id @default(uuid())
  documentId        String   @unique
  title             String
  domain            String
  content           String
  metadata          Json?    
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model KnowledgeEmbedding {
  metadata  Json
  embedding Unsupported("vector")?
  text      String
  id        String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  @@map("knowledge_embeddings")
}
